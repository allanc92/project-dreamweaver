# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# Provider: 'azure' for Azure OpenAI, 'local' for deterministic offline fallback
LLM_PROVIDER=azure

# Azure OpenAI resource (from Azure AI Foundry → your project → Keys and Endpoint)
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<key>
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Azure AI Foundry deployment names
AZURE_OPENAI_DEPLOYMENT=<your-llm-deployment-name>
AZURE_OPENAI_TTS_DEPLOYMENT=<your-tts-deployment-name>

# Optional: if your TTS model is in a different Azure resource, set these.
# If omitted, AZURE_OPENAI_ENDPOINT and AZURE_OPENAI_API_KEY are used for TTS too.
AZURE_OPENAI_TTS_ENDPOINT=https://<tts-resource>.openai.azure.com
AZURE_OPENAI_TTS_API_KEY=<tts-key>
